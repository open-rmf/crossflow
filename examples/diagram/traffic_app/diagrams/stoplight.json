  "description": "Drive forward, stopping for traffic lights along the way. Runs for 10 seconds unless you input a different duration (in seconds).",
  "input_examples": [
    {
      "description": "Run for 30 seconds.",
      "value": "30"
    }
  ],
  "script_environments": {
    "scripts": {
      "builder": "process-bound-python",
      "config": {
        "ownership": "shared",
        "script": "import asyncio\nfrom crossflow import *\n\nasync def execute(input: Input):\n    stoplight = input.accessors['stoplight'].fetch_by_clone()\n    \n    duration = input.data\n    if duration is None:\n        duration = 10.0\n    \n    dt = 0.1\n    t = 0.0\n    while t < duration:\n        t += dt\n        \n        light = await stoplight.try_fetch()\n\n        if light == 'red':\n            stop = {\n                'target_speed': 0,\n                'max_acceleration': 100\n            }\n            input.stream_out('speed', stop)\n        else:\n            input.stream_out('speed', 30)\n        await asyncio.sleep(dt)\n\ndef print_messages(input: Input):\n    print(f'Traffic signal: {input.data}')\n\ndef stop(input: Input):\n    input.stream_out('speed', 0)"
      }
    }
  },
