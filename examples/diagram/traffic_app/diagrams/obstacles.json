    },
    "detect_kinematics": {
      "type": "node",
      "builder": "detect_kinematics",
      "next": {
        "builtin": "dispose"
      },
      "stream_out": {
        "kinematics": "kinematics_buffer"
      }
    },
    "kinematics_buffer": {
      "type": "buffer"
    },
    "kinematics_buffer_access": {
      "type": "buffer_access",
      "buffers": [
        "kinematics_buffer"
      ],
      "next": "process_kinematics"
    },
    "process_kinematics": {
