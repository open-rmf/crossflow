    "traffic_signal_buffer": {
      "type": "buffer",
      "settings": {
        "retention": {
          "keep_last": 1
        }
      }
    },
    "start_engine_fork_clone": {
      "type": "fork_clone",
      "next": [
        "wait_for_destination_reached",
        "configure_obstacles_thresholds",
        "abandon_trip",
        "detect_kinematics"
      ]
