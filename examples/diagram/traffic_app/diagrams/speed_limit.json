      "type": "node",
      "builder": "check_speed_limit",
      "next": {
        "builtin": "dispose"
      },
      "stream_out": {
        "speed_limit": "traffic_signal_buffer"
      }
    },
    "traffic_signal_buffer": {
      "type": "buffer",
      "settings": {
        "retention": {
          "keep_last": 1
        }
      }
    },
    "start_engine_fork_clone": {
      "type": "fork_clone",
      "next": [
        "check_speed_limit",
        "wait_for_destination_reached",
        "abandon_trip",
        "detect_kinematics"
      ]
