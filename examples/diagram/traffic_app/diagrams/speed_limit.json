        "builtin": "dispose"
      }
    },
    "trigger_fork_clone": {
      "type": "fork_clone",
      "next": [
        "kinematics_buffer_access",
        "traffic_signal_buffer_access"
      ]
    },
    "trip_error": {
      "type": "node",
      "builder": "trip_error",
      "next": "stop_engine"
    }
  },
