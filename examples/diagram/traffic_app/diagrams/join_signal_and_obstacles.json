      "type": "fork_clone",
      "next": [
        "detect_obstacles",
        "detect_traffic_signal"
      ]
    },
    "obstacles_buffer": {
      "type": "buffer",
      "settings": {
        "retention": {
          "keep_last": 10
        }
      }
    },
    "detect_traffic_signal": {
      "type": "node",
      "builder": "detect_traffic_signal",
      "next": {
        "builtin": "dispose"
      },
      "stream_out": {
        "traffic_signal": "traffic_signal_buffer"
      }
    },
    "start_engine": {
      "type": "node",
      "builder": "start_engine",
      "next": "start_engine_fork_result"
    },
    "move_vehicle": {
      "type": "node",
      "builder": "move_vehicle",
      "next": "destination_reached"
    },
    "destination_reached": {
      "type": "node",
      "builder": "destination_reached",
      "next": "destination_reached_fork_result"
    },
    "destination_reached_fork_result": {
