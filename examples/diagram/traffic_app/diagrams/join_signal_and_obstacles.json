      "settings": {
        "retention": {
          "keep_last": 10
        }
      }
    },
    "start_engine_fork_clone": {
      "type": "fork_clone",
      "next": [
        "detect_obstacles",
        "detect_traffic_signal",
        "abandon_trip",
        "detect_kinematics",
        "wait_for_destination_reached"
