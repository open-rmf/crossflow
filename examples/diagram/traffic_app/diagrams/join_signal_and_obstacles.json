        "builtin": "dispose"
      },
      "ok": "move_vehicle"
    },
    "detect_obstacles": {
      "type": "node",
      "builder": "detect_obstacles",
      "next": {
        "builtin": "dispose"
      },
      "stream_out": {
        "obstacles": "obstacles_buffer"
      }
    },
    "traffic_signal_buffer": {
      "type": "buffer"
    },
    "join_traffic_signal_and_obstacles": {
      "type": "node",
      "builder": "join_traffic_signal_and_obstacles",
      "next": "join_fork_result"
    },
    "join": {
      "type": "join",
      "buffers": {
        "traffic_signal": "traffic_signal_buffer",
        "obstacles": "obstacles_buffer"
      },
      "next": "join_traffic_signal_and_obstacles"
    },
    "start_engine_fork_result": {
      "type": "fork_result",
      "err": "trip_error",
      "ok": "start_engine_fork_clone"
    },
    "trip_error": {
      "type": "node",
      "builder": "trip_error",
      "next": "stop_engine"
    }
  },
  "description": "A workflow that moves the vehicle forward until it travelled the requested distance, while respecting both traffic light signals and obstacle avoidance.",
