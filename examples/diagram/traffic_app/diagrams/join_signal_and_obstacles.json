        "obstacles": "obstacles_buffer"
      }
    },
    "join_fork_result": {
      "type": "fork_result",
      "err": {
        "builtin": "dispose"
      },
      "ok": "accelerate_vehicle"
    },
    "stop_engine": {
      "type": "node",
      "builder": "stop_engine",
      "next": {
        "builtin": "terminate"
      }
    },
    "accelerate_vehicle": {
