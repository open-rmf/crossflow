  "script_environments": {
    "scripts": {
      "builder": "process-bound-python",
      "config": {
        "ownership": "shared",
        "script": "import asyncio\nfrom crossflow import *\n\nasync def execute(input: Input):\n    stoplight = input.accessors['stoplight'].fetch_by_clone()\n    obstacles = input.accessors['obstacles'].fetch_by_clone()\n    stop_requested = input.accessors['stop_requested'].fetch_by_clone()\n\n    previously_stopped = False\n    while True:\n        if await stop_requested.try_fetch() is not None:\n            print('Stopping because of user request')\n            # The user asked us to stop\n            return\n        \n        light = await stoplight.try_fetch()\n\n        stop = False\n        if light == 'red':\n            # Stop if we a see a red light\n            stop = True\n            if not previously_stopped:\n                print('Stopping for a red light')\n\n        if not stop:\n            current_obstacles = await obstacles.try_fetch()\n            if current_obstacles is not None:\n                for obs in current_obstacles:\n                    if abs(obs['x']) < 2.0:\n                        # Stop if an obstacle is in front of us\n                        stop = True\n                        if not previously_stopped:\n                            print('Stopping for an obstacle')\n                        break\n\n        if stop:\n            previously_stopped = True\n            stop = {\n                'target_speed': 0,\n                'max_acceleration': 100\n            }\n            input.stream_out('speed', stop)\n        else:\n            previously_stopped = False\n            input.stream_out('speed', 30)\n        await asyncio.sleep(0.1)\n\ndef print_messages(input: Input):\n    print(f'Traffic signal: {input.data}')\n\ndef stop(input: Input):\n    input.stream_out('speed', 0)"
      }
    }
  },
